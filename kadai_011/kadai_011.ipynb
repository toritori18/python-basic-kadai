        "# @title\n",
        "array = [\"水\",\"金\",\"地\",\"火\",\"木\",\"土\",\"天\",\"海\",\"冥\"]\n",
        "\n",
        "# for文\n",
        "for i in range(1,9):\n",
        " print(array[i])\n",
        "\n",
        "# while文\n",
        "num = 0\n",
        "while num < len(array):\n",
        "  print(array[num])\n",
        "  num = num + 1\n"
      ],
