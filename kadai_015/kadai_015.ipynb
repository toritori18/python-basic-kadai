        "\n",
        "class Human:\n",
        "    # コンストラクタ\n",
        "    def __init__ (self,name,age):\n",
        "        self.name = name\n",
        "        self.age = age\n",
        "\n",
        "    # 出力\n",
        "    def printinfo(self):\n",
        "\n",
        "        print(\"名前：\" + self.name)\n",
        "        print(\"年齢：\" + str(self.age))\n",
        "\n",
        "human = Human(\"侍太郎\", 36)\n",
        "human.printinfo()\n",
        "\n"
      ],
