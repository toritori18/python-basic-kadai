        "# 関数\n",
        "def syouhizei(kingaku : int,zei : int):\n",
        "\n",
        "    return kingaku + kingaku * zei / 100\n",
        "\n",
        "# @title\n",
        "kingaku = 110\n",
        "zei = 10\n",
        "\n",
        "print(syouhizei(kingaku,zei))\n"
